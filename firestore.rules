rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow any authenticated user (including anonymous) to read and write to protocol data
    // This is a permissive rule set for prototype development.
    match /protocol/{document=**} {
      allow read, write: if request.auth != null;
    }
    match /validators/{document=**} {
      allow read, write: if request.auth != null;
    }
    match /stakes/{document=**} {
      allow read, write: if request.auth != null;
    }
    match /proposals/{document=**} {
      allow read, write: if request.auth != null;
    }
    match /licenses/{document=**} {
      allow read, write: if request.auth != null;
    }
    match /users/{userId} {
      allow read, write: if request.auth != null;
    }
  }
}